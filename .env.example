# 🤖 AI BRAIN CONFIGURATION
# Your Google Gemini API Key (Stored in GitHub Secrets)
BACK_GEMINI_API_KEY=your_key_is_stored_in_secrets

# 🛡️ GLOBAL USER PROTECTION
# Enables the VPN and IP Masking features you requested
ENABLE_GLOBAL_VPN=true
ENABLE_IP_MASKING=true

# 🖥️ PC & BROWSER SETTINGS
BACK_PORT=3001
BACK_CORS_ORIGIN=http://localhost:5173

# 🎨 PROJECT SETTINGS
# Target project for the "User Zero" test
CURRENT_GOAL=EIFFEL_TOWER_3D_MODEL
USER_KNOWLEDGE_LEVEL=0_TECHNICAL_KNOWLEDGE
